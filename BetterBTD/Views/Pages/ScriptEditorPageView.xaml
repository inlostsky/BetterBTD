<Page x:Class="BetterBTD.Views.Pages.ScriptEditorPageView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:vio="http://schemas.lepo.co/wpfui/2022/xaml/violeta"
      xmlns:dd="urn:gong-wpf-dragdrop"
      xmlns:converters="clr-namespace:BetterBTD.Views.Converters"
      mc:Ignorable="d">
    <Page.Resources>
        <converters:MapTypeToCascadingItemConverter x:Key="MapTypeToCascadingItemConverter" />
        <converters:MonkeyTowerTypeToCascadingItemConverter x:Key="MonkeyTowerTypeToCascadingItemConverter" />
        <converters:ScriptInstructionTypeToVisibilityConverter x:Key="ScriptInstructionTypeToVisibilityConverter" />

        <Style x:Key="FlatListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style x:Key="TransparentListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InstructionCardBorderStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorSecondaryBrush}" />
            <Setter Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentStrokeColorDefaultBrush}" />
                    <Setter Property="Background" Value="{DynamicResource AccentFillColorDefaultBrush}" />
                    <Setter Property="BorderThickness" Value="2" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid x:Name="EditorRoot" Margin="42,16,42,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:CardControl Grid.Row="0" Style="{StaticResource AppCardControlStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <ui:Button Grid.Column="0" Margin="0,0,8,0" Appearance="Primary" Content="{Binding FileOpenText}" Icon="{ui:SymbolIcon FolderOpen24}" />
                <ui:DropDownButton Grid.Column="1" Margin="0,0,8,0" Content="{Binding FileSaveText}" Icon="{ui:SymbolIcon Save24}">
                    <ui:DropDownButton.Flyout>
                        <ContextMenu>
                            <MenuItem Header="{Binding PlacementTarget.DataContext.FileSaveText, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                            <MenuItem Header="{Binding PlacementTarget.DataContext.FileSaveAsText, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                        </ContextMenu>
                    </ui:DropDownButton.Flyout>
                </ui:DropDownButton>
                <ui:Button Grid.Column="2" Margin="0,0,8,0" Content="{Binding FileNewText}" Icon="{ui:SymbolIcon DocumentAdd24}" />
                <ui:Button Grid.Column="3"
                           Margin="0,0,6,0"
                           Padding="6"
                           Appearance="Transparent"
                           BorderThickness="0"
                           Icon="{ui:SymbolIcon ArrowUndo24}"
                           Command="{Binding UndoSequenceCommand}" />
                <ui:Button Grid.Column="4"
                           Margin="0,0,8,0"
                           Padding="6"
                           Appearance="Transparent"
                           BorderThickness="0"
                           Icon="{ui:SymbolIcon ArrowRedo24}"
                           Command="{Binding RedoSequenceCommand}" />

                <TextBlock Grid.Column="6"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0"
                           Text="{Binding CurrentFileText}"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />

                <ui:Button Grid.Column="7"
                           Content="{Binding DebugRunText}"
                           Icon="{ui:SymbolIcon Play24}"
                           Appearance="Primary" />
            </Grid>
        </ui:CardControl>

        <ui:CardControl Grid.Row="1" Style="{StaticResource AppCardControlStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel Margin="0,0,12,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding MetadataMapText}" Style="{StaticResource CardDescriptionTextStyle}" />
                        <vio:CascadingComboBox Width="180"
                                               Margin="0,4,0,0"
                                               PlaceholderText="{Binding MetadataMapPlaceholderText}"
                                               ItemsSource="{Binding MapItems}"
                                               SelectedCascadingItem="{Binding SelectedMap, Mode=TwoWay, Converter={StaticResource MapTypeToCascadingItemConverter}}" />
                    </StackPanel>

                    <StackPanel Margin="0,0,12,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding MetadataDifficultyText}" Style="{StaticResource CardDescriptionTextStyle}" />
                        <ComboBox Width="140"
                                  Margin="0,4,0,0"
                                  DisplayMemberPath="DisplayName"
                                  ItemsSource="{Binding DifficultyOptions}"
                                  SelectedItem="{Binding SelectedDifficultyOption, Mode=TwoWay}" />
                    </StackPanel>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding MetadataModeText}" Style="{StaticResource CardDescriptionTextStyle}" />
                        <ComboBox Width="140"
                                  Margin="0,4,0,0"
                                  DisplayMemberPath="DisplayName"
                                  ItemsSource="{Binding ModeOptions}"
                                  SelectedItem="{Binding SelectedModeOption, Mode=TwoWay}" />
                    </StackPanel>

                    <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding MetadataHeroText}" Style="{StaticResource CardDescriptionTextStyle}" />
                        <ComboBox Width="140"
                                  Margin="0,4,0,0"
                                  DisplayMemberPath="DisplayName"
                                  ItemsSource="{Binding HeroOptions}"
                                  SelectedItem="{Binding SelectedHeroOption, Mode=TwoWay}" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </ui:CardControl>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="{Binding LibraryTitle}" Style="{StaticResource CardTitleTextStyle}" />

                    <ListBox Grid.Row="1"
                             Margin="0,10,0,0"
                             Style="{StaticResource FlatListBoxStyle}"
                             ItemContainerStyle="{StaticResource TransparentListBoxItemStyle}"
                             SelectionMode="Extended"
                             ItemsSource="{Binding InstructionLibrary}"
                             SelectedItem="{Binding SelectedLibraryInstruction, Mode=TwoWay}"
                             dd:DragDrop.IsDragSource="True"
                             dd:DragDrop.UseDefaultDragAdorner="True"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,8"
                                        Padding="10"
                                        CornerRadius="8"
                                        BorderThickness="1"
                                        Style="{StaticResource InstructionCardBorderStyle}">
                                    <TextBlock Text="{Binding DisplayName}" Style="{StaticResource CardTitleTextStyle}" />
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>


                <Grid  Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="{Binding SequenceTitle}" Style="{StaticResource CardTitleTextStyle}" />

                    <Border Grid.Row="1"
                            Margin="0,10,0,0"
                            CornerRadius="8"
                            BorderThickness="1"
                            BorderBrush="{DynamicResource ControlStrokeColorSecondaryBrush}"
                            Background="{DynamicResource ControlFillColorSecondaryBrush}">
                        <ListBox Margin="10"
                                 Style="{StaticResource FlatListBoxStyle}"
                                 ItemContainerStyle="{StaticResource TransparentListBoxItemStyle}"
                                 SelectionMode="Extended"
                                 ItemsSource="{Binding InstructionSequence}"
                                 SelectedItem="{Binding SelectedSequenceInstruction, Mode=TwoWay}"
                                 dd:DragDrop.IsDragSource="True"
                                 dd:DragDrop.IsDropTarget="True"
                                 dd:DragDrop.UseDefaultDragAdorner="True"
                                 dd:DragDrop.SelectDroppedItems="True"
                                 dd:DragDrop.DropHandler="{Binding}"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ScrollViewer.CanContentScroll="True"
                                 VirtualizingPanel.IsVirtualizing="True"
                                 VirtualizingPanel.VirtualizationMode="Recycling">
                            <ListBox.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="{Binding CopySelectedInstructionText}"
                                              Command="{Binding CopySelectedSequenceInstructionsCommand}"
                                              CommandParameter="{Binding PlacementTarget.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                    <MenuItem Header="{Binding PasteInstructionText}"
                                              Command="{Binding PasteSequenceInstructionsCommand}"
                                              CommandParameter="{Binding PlacementTarget.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                    <Separator />
                                    <MenuItem Header="{Binding DeleteSelectedInstructionText}"
                                              Command="{Binding DeleteSelectedSequenceInstructionsCommand}"
                                              CommandParameter="{Binding PlacementTarget.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                </ContextMenu>
                            </ListBox.ContextMenu>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8"
                                            Padding="10"
                                            CornerRadius="8"
                                            BorderThickness="1"
                                            Style="{StaticResource InstructionCardBorderStyle}">
                                        <TextBlock Text="{Binding DisplayName}" Style="{StaticResource CardTitleTextStyle}" />
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>

                    <TextBlock Grid.Row="2"
                                Margin="0,10,0,0"
                                Text="{Binding SequenceEmptyText}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource CardDescriptionTextStyle}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding InstructionSequence.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <Grid Grid.Column="4" Margin="0,0,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="{Binding PropertiesTitle}" Style="{StaticResource CardTitleTextStyle}" />

                    <StackPanel Grid.Row="1" Margin="0,10,0,0">
                        <TextBlock Text="{Binding PropertiesEmptyText}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource CardDescriptionTextStyle}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedSequenceInstruction}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <StackPanel>
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedSequenceInstruction}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>

                            <StackPanel Margin="0,0,0,10"
                                        Visibility="{Binding SelectedSequenceInstruction.Type, Converter={StaticResource ScriptInstructionTypeToVisibilityConverter}, ConverterParameter=PlaceMonkey}">
                                <TextBlock Text="{Binding PropertyMonkeyTowerText}" Style="{StaticResource CardDescriptionTextStyle}" />
                                <vio:CascadingComboBox Margin="0,4,0,10"
                                                       PlaceholderText="{Binding MetadataMapPlaceholderText}"
                                                       ItemsSource="{Binding MonkeyTowerItems}"
                                                       SelectedCascadingItem="{Binding SelectedSequenceInstruction.SelectedMonkeyTower, Mode=TwoWay, Converter={StaticResource MonkeyTowerTypeToCascadingItemConverter}}" />

                                <TextBlock Text="{Binding PropertyCoordinateText}" Style="{StaticResource CardDescriptionTextStyle}" />
                                <StackPanel Margin="0,4,0,0">
                                    <TextBlock Text="X" Style="{StaticResource CardDescriptionTextStyle}" />
                                    <ui:NumberBox Margin="0,2,0,8" Value="{Binding SelectedSequenceInstruction.PositionX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Y" Style="{StaticResource CardDescriptionTextStyle}" />
                                    <ui:NumberBox Margin="0,2,0,0" Value="{Binding SelectedSequenceInstruction.PositionY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Margin="0,0,0,10"
                                        Visibility="{Binding SelectedSequenceInstruction.Type, Converter={StaticResource ScriptInstructionTypeToVisibilityConverter}, ConverterParameter=UpgradeMonkey}">
                                <TextBlock Text="{Binding PropertyTargetMonkeyText}" Style="{StaticResource CardDescriptionTextStyle}" />
                                <ComboBox Margin="0,4,0,10"
                                          DisplayMemberPath="DisplayName"
                                          SelectedValuePath="Code"
                                          ItemsSource="{Binding MonkeyObjectOptions}"
                                          SelectedValue="{Binding SelectedSequenceInstruction.TargetMonkeyObjectId, Mode=TwoWay}" />

                                <StackPanel>
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedSequenceInstruction.ShowUpgradePathSelector}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <TextBlock Text="{Binding PropertyUpgradePathText}" Style="{StaticResource CardDescriptionTextStyle}" />
                                    <ComboBox Margin="0,4,0,10"
                                              DisplayMemberPath="DisplayName"
                                              SelectedValuePath="Code"
                                              ItemsSource="{Binding UpgradePathOptions}"
                                              SelectedValue="{Binding SelectedSequenceInstruction.UpgradePath, Mode=TwoWay}" />
                                </StackPanel>

                                <TextBlock Text="{Binding PropertyUpgradeCountText}" Style="{StaticResource CardDescriptionTextStyle}" />
                                <ui:NumberBox Margin="0,4,0,0"
                                              Minimum="1"
                                              Maximum="5"
                                              Value="{Binding SelectedSequenceInstruction.UpgradeCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel Margin="0,0,0,10"
                                        Visibility="{Binding SelectedSequenceInstruction.Type, Converter={StaticResource ScriptInstructionTypeToVisibilityConverter}, ConverterParameter=SwitchMonkeyTarget}">
                                <TextBlock Text="{Binding PropertyTargetMonkeyText}" Style="{StaticResource CardDescriptionTextStyle}" />
                                <ComboBox Margin="0,4,0,10"
                                          DisplayMemberPath="DisplayName"
                                          SelectedValuePath="Code"
                                          ItemsSource="{Binding MonkeyObjectOptions}"
                                          SelectedValue="{Binding SelectedSequenceInstruction.TargetMonkeyObjectId, Mode=TwoWay}" />

                                <TextBlock Text="{Binding PropertySwitchDirectionText}" Style="{StaticResource CardDescriptionTextStyle}" />
                                <ComboBox Margin="0,4,0,10"
                                          DisplayMemberPath="DisplayName"
                                          SelectedValuePath="Code"
                                          ItemsSource="{Binding SwitchDirectionOptions}"
                                          SelectedValue="{Binding SelectedSequenceInstruction.SwitchDirection, Mode=TwoWay}" />

                                <TextBlock Text="{Binding PropertySwitchCountText}" Style="{StaticResource CardDescriptionTextStyle}" />
                                <ui:NumberBox Margin="0,4,0,0"
                                              Minimum="1"
                                              Maximum="3"
                                              Value="{Binding SelectedSequenceInstruction.SwitchCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel Margin="0,0,0,10"
                                        Visibility="{Binding SelectedSequenceInstruction.Type, Converter={StaticResource ScriptInstructionTypeToVisibilityConverter}, ConverterParameter=SetMonkeyAbility}">
                                <TextBlock Text="{Binding PropertyTargetMonkeyText}" Style="{StaticResource CardDescriptionTextStyle}" />
                                <ComboBox Margin="0,4,0,10"
                                          DisplayMemberPath="DisplayName"
                                          SelectedValuePath="Code"
                                          ItemsSource="{Binding MonkeyObjectOptions}"
                                          SelectedValue="{Binding SelectedSequenceInstruction.TargetMonkeyObjectId, Mode=TwoWay}" />

                                <TextBlock Text="{Binding PropertyAbilityText}" Style="{StaticResource CardDescriptionTextStyle}" />
                                <ComboBox Margin="0,4,0,10"
                                          DisplayMemberPath="DisplayName"
                                          SelectedValuePath="Code"
                                          ItemsSource="{Binding MonkeyAbilityOptions}"
                                          SelectedValue="{Binding SelectedSequenceInstruction.SelectedAbility, Mode=TwoWay}" />

                                <ui:ToggleSwitch Margin="0,4,0,10"
                                                 Content="{Binding PropertyNeedAbilityCoordinateText}"
                                                 IsChecked="{Binding SelectedSequenceInstruction.RequiresAbilityCoordinate, Mode=TwoWay}" />

                                <StackPanel Margin="0,0,0,0">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedSequenceInstruction.RequiresAbilityCoordinate}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <TextBlock Text="X" Style="{StaticResource CardDescriptionTextStyle}" />
                                    <ui:NumberBox Margin="0,2,0,8" Value="{Binding SelectedSequenceInstruction.AbilityCoordinateX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Y" Style="{StaticResource CardDescriptionTextStyle}" />
                                    <ui:NumberBox Margin="0,2,0,0" Value="{Binding SelectedSequenceInstruction.AbilityCoordinateY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Margin="0,0,0,10"
                                        Visibility="{Binding SelectedSequenceInstruction.Type, Converter={StaticResource ScriptInstructionTypeToVisibilityConverter}, ConverterParameter=PlaceHeroInventory}">
                                <TextBlock Text="{Binding PropertyInventoryText}" Style="{StaticResource CardDescriptionTextStyle}" />
                                <ComboBox Margin="0,4,0,10"
                                          DisplayMemberPath="DisplayName"
                                          SelectedValuePath="Code"
                                          ItemsSource="{Binding InventoryOptions}"
                                          SelectedValue="{Binding SelectedSequenceInstruction.SelectedInventoryItem, Mode=TwoWay}" />

                                <ui:ToggleSwitch Margin="0,4,0,10"
                                                 Content="{Binding PropertyNeedCoordinateText}"
                                                 IsChecked="{Binding SelectedSequenceInstruction.RequiresAbilityCoordinate, Mode=TwoWay}" />

                                <StackPanel>
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedSequenceInstruction.RequiresAbilityCoordinate}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <TextBlock Text="X" Style="{StaticResource CardDescriptionTextStyle}" />
                                    <ui:NumberBox Margin="0,2,0,8" Value="{Binding SelectedSequenceInstruction.PositionX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Y" Style="{StaticResource CardDescriptionTextStyle}" />
                                    <ui:NumberBox Margin="0,2,0,0" Value="{Binding SelectedSequenceInstruction.PositionY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Margin="0,0,0,10"
                                        Visibility="{Binding SelectedSequenceInstruction.Type, Converter={StaticResource ScriptInstructionTypeToVisibilityConverter}, ConverterParameter=ActivateAbility}">
                                <TextBlock Text="{Binding PropertyActivatedAbilityText}" Style="{StaticResource CardDescriptionTextStyle}" />
                                <ComboBox Margin="0,4,0,10"
                                          DisplayMemberPath="DisplayName"
                                          SelectedValuePath="Code"
                                          ItemsSource="{Binding ActivatedAbilityOptions}"
                                          SelectedValue="{Binding SelectedSequenceInstruction.SelectedActivatedAbility, Mode=TwoWay}" />

                                <ui:ToggleSwitch Margin="0,4,0,10"
                                                 Content="{Binding PropertyNeedCoordinateText}"
                                                 IsChecked="{Binding SelectedSequenceInstruction.RequiresAbilityCoordinate, Mode=TwoWay}" />

                                <StackPanel>
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedSequenceInstruction.RequiresAbilityCoordinate}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <TextBlock Text="X" Style="{StaticResource CardDescriptionTextStyle}" />
                                    <ui:NumberBox Margin="0,2,0,8" Value="{Binding SelectedSequenceInstruction.AbilityCoordinateX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="Y" Style="{StaticResource CardDescriptionTextStyle}" />
                                    <ui:NumberBox Margin="0,2,0,0" Value="{Binding SelectedSequenceInstruction.AbilityCoordinateY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Margin="0,0,0,10"
                                        Visibility="{Binding SelectedSequenceInstruction.Type, Converter={StaticResource ScriptInstructionTypeToVisibilityConverter}, ConverterParameter=NextRound}">
                                <TextBlock Text="{Binding PropertyNextRoundActionText}" Style="{StaticResource CardDescriptionTextStyle}" />
                                <ComboBox Margin="0,4,0,0"
                                          DisplayMemberPath="DisplayName"
                                          SelectedValuePath="Code"
                                          ItemsSource="{Binding NextRoundActionOptions}"
                                          SelectedValue="{Binding SelectedSequenceInstruction.NextRoundAction, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                <StackPanel Margin="0,10,0,0">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedSequenceInstruction.ShowNextRoundSendCount}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>

                                    <TextBlock Text="{Binding PropertyNextRoundSendCountText}" Style="{StaticResource CardDescriptionTextStyle}" />
                                    <ui:NumberBox Margin="0,4,0,0"
                                                  Minimum="1"
                                                  Maximum="500"
                                                  Value="{Binding SelectedSequenceInstruction.NextRoundSendCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Margin="0,0,0,10"
                                        Visibility="{Binding SelectedSequenceInstruction.Type, Converter={StaticResource ScriptInstructionTypeToVisibilityConverter}, ConverterParameter=SellMonkey}">
                                <TextBlock Text="{Binding PropertyTargetMonkeyText}" Style="{StaticResource CardDescriptionTextStyle}" />
                                <ComboBox Margin="0,4,0,0"
                                          DisplayMemberPath="DisplayName"
                                          SelectedValuePath="Code"
                                          ItemsSource="{Binding MonkeyObjectOptions}"
                                          SelectedValue="{Binding SelectedSequenceInstruction.TargetMonkeyObjectId, Mode=TwoWay}" />
                            </StackPanel>

                            <TextBlock Text="{Binding PropertyNotesText}" Style="{StaticResource CardDescriptionTextStyle}" />
                            <TextBox Margin="0,4,0,0"
                                     MinHeight="100"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     Text="{Binding SelectedSequenceInstruction.Notes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Page>