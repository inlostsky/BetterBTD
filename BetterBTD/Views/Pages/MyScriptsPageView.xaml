<Page x:Class="BetterBTD.Views.Pages.MyScriptsPageView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:vio="http://schemas.lepo.co/wpfui/2022/xaml/violeta"
      mc:Ignorable="d">
    <Page.Resources>
        <Style x:Key="FlatScriptListStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style x:Key="TransparentScriptListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="SelectionBackground"
                                Background="Transparent"
                                CornerRadius="6">
                            <Grid>
                                <Border x:Name="SelectionIndicator"
                                        Width="3"
                                        HorizontalAlignment="Left"
                                        Background="Transparent"
                                        CornerRadius="2" />
                                <ContentPresenter Margin="8,0,0,0" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="SelectionBackground"
                                        Property="Background"
                                        Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                                <Setter TargetName="SelectionIndicator"
                                        Property="Background"
                                        Value="{DynamicResource AccentFillColorDefaultBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Margin="42,16,42,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:CardControl Grid.Row="0" Style="{StaticResource AppCardControlStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <ui:Button Grid.Column="0"
                           Margin="0,0,8,0"
                           Appearance="Primary"
                           Content="{Binding ImportText}"
                           Command="{Binding ImportScriptCommand}" />
                <ui:Button Grid.Column="1"
                           Margin="0,0,8,0"
                           Appearance="Secondary"
                           Content="{Binding ExportText}"
                           Command="{Binding ExportSelectedScriptCommand}" />
                <ui:Button Grid.Column="2"
                           Margin="0,0,8,0"
                           Appearance="Secondary"
                           Content="{Binding RemoveText}"
                           Command="{Binding RemoveSelectedScriptCommand}" />
                <ui:Button Grid.Column="3"
                           Margin="0,0,8,0"
                           Appearance="Secondary"
                           Content="{Binding EditText}"
                           IsEnabled="{Binding HasSelectedScript}"
                           Click="EditSelectedScriptButton_OnClick" />
                <ui:Button Grid.Column="4"
                           Margin="0,0,8,0"
                           Appearance="Secondary"
                           Content="{Binding RunText}"
                           IsEnabled="{Binding HasSelectedScript}"
                           Click="RunSelectedScriptButton_OnClick" />
                <ui:Button Grid.Column="5"
                           Margin="0,0,8,0"
                           Appearance="Secondary"
                           Content="{Binding RefreshText}"
                           Command="{Binding RefreshCommand}" />

                <TextBlock Grid.Column="6"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                           Text="{Binding SelectedScriptSummary}"
                           TextAlignment="Right"
                           TextTrimming="CharacterEllipsis" />
            </Grid>
        </ui:CardControl>

        <ui:CardControl Grid.Row="1" Style="{StaticResource AppCardControlStyle}">
            <Grid VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,12,0" VerticalAlignment="Center">
                    <TextBlock Style="{StaticResource CardDescriptionTextStyle}" Text="{Binding ScriptSearchLabel}" />
                    <ui:TextBox Margin="0,4,0,0"
                                PlaceholderText="{Binding ScriptSearchPlaceholder}"
                                Text="{Binding ScriptSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,12,0" VerticalAlignment="Center">
                    <TextBlock Style="{StaticResource CardDescriptionTextStyle}" Text="{Binding MapFilterLabel}" />
                    <vio:CascadingComboBox Margin="0,4,0,0"
                                           ItemsSource="{Binding MapItems}"
                                           SelectedCascadingItem="{Binding SelectedMapItem, Mode=TwoWay}" />
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="0,0,12,0" VerticalAlignment="Center">
                    <TextBlock Style="{StaticResource CardDescriptionTextStyle}" Text="{Binding DifficultyFilterLabel}" />
                    <ComboBox Margin="0,4,0,0"
                              ItemsSource="{Binding DifficultyOptions}"
                              SelectedItem="{Binding SelectedDifficultyOption, Mode=TwoWay}"
                              DisplayMemberPath="DisplayName" />
                </StackPanel>

                <StackPanel Grid.Column="3" Margin="0,0,12,0" VerticalAlignment="Center">
                    <TextBlock Style="{StaticResource CardDescriptionTextStyle}" Text="{Binding ModeFilterLabel}" />
                    <ComboBox Margin="0,4,0,0"
                              ItemsSource="{Binding ModeOptions}"
                              SelectedItem="{Binding SelectedModeOption, Mode=TwoWay}"
                              DisplayMemberPath="DisplayName" />
                </StackPanel>
            </Grid>
        </ui:CardControl>

        <GridSplitter Grid.Row="2"
                      Height="1"
                      Margin="0,2,0,2"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Center"
                      Background="{DynamicResource ControlStrokeColorSecondaryBrush}"
                      ResizeDirection="Rows"
                      ResizeBehavior="PreviousAndNext"
                      ShowsPreview="False" />

        <Grid Grid.Row="3"
              Margin="0,12,0,0"
              MinHeight="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.18*" />
                <ColumnDefinition Width="0.82*" />
            </Grid.ColumnDefinitions>

            <ui:CardControl Grid.Column="0"
                            Margin="0,0,12,0"
                            MinHeight="0"
                            Style="{StaticResource AppCardControlStyle}">
                <Grid MinHeight="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel LastChildFill="False">
                        <TextBlock Style="{StaticResource CardTitleTextStyle}"
                                   Text="{Binding ScriptsSectionText}" />
                        <Border DockPanel.Dock="Right"
                                Padding="10,4"
                                CornerRadius="999"
                                Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                                BorderBrush="{DynamicResource ControlStrokeColorSecondaryBrush}"
                                BorderThickness="1">
                            <TextBlock Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                       Text="{Binding VisibleScriptCountText}" />
                        </Border>
                    </DockPanel>

                    <Grid Grid.Row="1"
                          Margin="0,16,0,0"
                          MinHeight="0">
                        <ListBox Style="{StaticResource FlatScriptListStyle}"
                                 ItemContainerStyle="{StaticResource TransparentScriptListBoxItemStyle}"
                                 ItemsSource="{Binding Scripts}"
                                 SelectedItem="{Binding SelectedScript, Mode=TwoWay}"
                                 MinHeight="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  Visibility="{Binding HasScripts, Converter={StaticResource BoolToVisibilityConverter}}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Border Width="28"
                                                Height="28"
                                                Margin="10,8,12,8"
                                                VerticalAlignment="Center"
                                                CornerRadius="6"
                                                Background="{DynamicResource ControlFillColorSecondaryBrush}">
                                            <ui:SymbolIcon HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                                                           Symbol="Document24" />
                                        </Border>

                                        <TextBlock Grid.Column="1"
                                                   Margin="0,0,10,0"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                   Text="{Binding DisplayName}"
                                                   TextTrimming="CharacterEllipsis" />
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Visibility="{Binding HasScripts, Converter={StaticResource BooleanToVisibilityRevertConverter}}">
                            <Border Width="60"
                                    Height="60"
                                    CornerRadius="20"
                                    Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                    BorderBrush="{DynamicResource ControlStrokeColorSecondaryBrush}"
                                    BorderThickness="1">
                                <TextBlock HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontSize="24"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                           Text="S" />
                            </Border>
                            <TextBlock Margin="0,14,0,0"
                                       HorizontalAlignment="Center"
                                       Style="{StaticResource PageDescriptionTextStyle}"
                                       Text="{Binding EmptyScriptsText}"
                                       TextAlignment="Center" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </ui:CardControl>

            <ui:CardControl Grid.Column="1"
                            Margin="12,0,0,0"
                            MinHeight="0"
                            Style="{StaticResource AppCardControlStyle}">
                <Grid MinHeight="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Style="{StaticResource CardTitleTextStyle}"
                               Text="{Binding PropertiesSectionText}" />

                    <ScrollViewer Grid.Row="1"
                                  Margin="0,16,0,0"
                                  MinHeight="0"
                                  VerticalScrollBarVisibility="Auto"
                                  Visibility="{Binding HasSelectedScript, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="116" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Grid.Column="0"
                                       Margin="0,0,12,12"
                                       VerticalAlignment="Top"
                                       Style="{StaticResource CardDescriptionTextStyle}"
                                       Text="{Binding PropertyNameText}" />
                            <TextBlock Grid.Row="0"
                                       Grid.Column="1"
                                       Margin="0,0,0,12"
                                       Text="{Binding SelectedScriptName}"
                                       TextWrapping="Wrap" />

                            <TextBlock Grid.Row="1"
                                       Grid.Column="0"
                                       Margin="0,0,12,12"
                                       VerticalAlignment="Top"
                                       Style="{StaticResource CardDescriptionTextStyle}"
                                       Text="{Binding PropertyDescriptionText}" />
                            <TextBlock Grid.Row="1"
                                       Grid.Column="1"
                                       Margin="0,0,0,12"
                                       Text="{Binding SelectedScriptDescription}"
                                       TextWrapping="Wrap" />

                            <TextBlock Grid.Row="2"
                                       Grid.Column="0"
                                       Margin="0,0,12,12"
                                       VerticalAlignment="Top"
                                       Style="{StaticResource CardDescriptionTextStyle}"
                                       Text="{Binding PropertyScriptIdText}" />
                            <Grid Grid.Row="2"
                                  Grid.Column="1"
                                  Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Margin="0,0,8,0"
                                           VerticalAlignment="Center"
                                           Text="{Binding SelectedScriptId}"
                                           TextWrapping="Wrap" />
                                <ui:Button Grid.Column="1"
                                           MinWidth="76"
                                           Padding="10,4"
                                           Appearance="Secondary"
                                           Command="{Binding CopySelectedScriptIdCommand}"
                                           Content="{Binding CopyScriptIdText}"
                                           Icon="{ui:SymbolIcon Copy24}" />
                            </Grid>

                            <TextBlock Grid.Row="3"
                                       Grid.Column="0"
                                       Margin="0,0,12,12"
                                       Style="{StaticResource CardDescriptionTextStyle}"
                                       Text="{Binding PropertyHeroText}" />
                            <TextBlock Grid.Row="3"
                                       Grid.Column="1"
                                       Margin="0,0,0,12"
                                       Text="{Binding SelectedScriptHero}"
                                       TextWrapping="Wrap" />

                            <TextBlock Grid.Row="4"
                                       Grid.Column="0"
                                       Margin="0,0,12,12"
                                       Style="{StaticResource CardDescriptionTextStyle}"
                                       Text="{Binding PropertyMapText}" />
                            <TextBlock Grid.Row="4"
                                       Grid.Column="1"
                                       Margin="0,0,0,12"
                                       Text="{Binding SelectedScriptMap}"
                                       TextWrapping="Wrap" />

                            <TextBlock Grid.Row="5"
                                       Grid.Column="0"
                                       Margin="0,0,12,12"
                                       Style="{StaticResource CardDescriptionTextStyle}"
                                       Text="{Binding PropertyDifficultyText}" />
                            <TextBlock Grid.Row="5"
                                       Grid.Column="1"
                                       Margin="0,0,0,12"
                                       Text="{Binding SelectedScriptDifficulty}"
                                       TextWrapping="Wrap" />

                            <TextBlock Grid.Row="6"
                                       Grid.Column="0"
                                       Margin="0,0,12,12"
                                       Style="{StaticResource CardDescriptionTextStyle}"
                                       Text="{Binding PropertyModeText}" />
                            <TextBlock Grid.Row="6"
                                       Grid.Column="1"
                                       Margin="0,0,0,12"
                                       Text="{Binding SelectedScriptMode}"
                                       TextWrapping="Wrap" />

                            <TextBlock Grid.Row="7"
                                       Grid.Column="0"
                                       Margin="0,0,12,12"
                                       Style="{StaticResource CardDescriptionTextStyle}"
                                       Text="{Binding PropertyTagsText}" />
                            <TextBlock Grid.Row="7"
                                       Grid.Column="1"
                                       Margin="0,0,0,12"
                                       Text="{Binding SelectedScriptTags}"
                                       TextWrapping="Wrap" />

                            <TextBlock Grid.Row="8"
                                       Grid.Column="0"
                                       Margin="0,0,12,12"
                                       Style="{StaticResource CardDescriptionTextStyle}"
                                       Text="{Binding PropertyStateText}" />
                            <TextBlock Grid.Row="8"
                                       Grid.Column="1"
                                       Margin="0,0,0,12"
                                       Text="{Binding SelectedScriptState}"
                                       TextWrapping="Wrap" />
                        </Grid>
                    </ScrollViewer>

                    <StackPanel Grid.Row="1"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Visibility="{Binding HasSelectedScript, Converter={StaticResource BooleanToVisibilityRevertConverter}}">
                        <TextBlock HorizontalAlignment="Center"
                                   Style="{StaticResource PageDescriptionTextStyle}"
                                   Text="{Binding SelectedScriptSummary}"
                                   TextAlignment="Center" />
                    </StackPanel>
                </Grid>
            </ui:CardControl>
        </Grid>
    </Grid>
</Page>
