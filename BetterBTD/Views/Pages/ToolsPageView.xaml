<Page x:Class="BetterBTD.Views.Pages.ToolsPageView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      mc:Ignorable="d">
    <StackPanel Margin="42,16,42,12">
            <StackPanel Margin="0,0,0,16">
                <ui:TextBlock FontSize="28" FontWeight="SemiBold" Text="{Binding PageTitle}" />
                <ui:TextBlock Margin="0,6,0,0"
                              Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                              Text="{Binding PageDescription}"
                              TextWrapping="Wrap" />
            </StackPanel>

            <ui:CardExpander Margin="0,0,0,12"
                             ContentPadding="0"
                             Icon="{ui:SymbolIcon Table24}"
                             IsExpanded="True">
                <ui:CardExpander.Header>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <ui:TextBlock Grid.Row="0" Grid.Column="0" FontWeight="SemiBold" Text="{Binding RoundCardTitle}" TextWrapping="Wrap" />
                        <ui:TextBlock Grid.Row="1"
                                      Grid.Column="0"
                                      Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                                      Text="{Binding RoundCardDescription}"
                                      TextWrapping="Wrap" />
                        <ui:Button Grid.Row="0"
                                   Grid.RowSpan="2"
                                   Grid.Column="1"
                                   Width="120"
                                   Margin="0,0,36,0"
                                   Command="{Binding CalculateRoundCommand}"
                                   Content="{Binding CalculateButtonText}" />
                    </Grid>
                </ui:CardExpander.Header>

                <StackPanel>
                    <Separator Margin="-18,0" BorderThickness="0,1,0,0" />
                    <Grid Margin="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <ui:TextBlock Grid.Row="0" Grid.Column="0" FontWeight="SemiBold" Text="{Binding StartRoundLabel}" />
                        <ui:TextBlock Grid.Row="1"
                                      Grid.Column="0"
                                      Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                                      Text="{Binding StartRoundDescription}"
                                      TextWrapping="Wrap" />
                        <ui:NumberBox Grid.Row="0"
                                      Grid.RowSpan="2"
                                      Grid.Column="1"
                                      Width="120"
                                      Margin="0,0,36,0"
                                      Minimum="1"
                                      Maximum="999"
                                      SmallChange="1"
                                      Value="{Binding StartRound, Mode=TwoWay}" />
                    </Grid>

                    <Separator Margin="-18,0" BorderThickness="0,1,0,0" />
                    <Grid Margin="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <ui:TextBlock Grid.Row="0" Grid.Column="0" FontWeight="SemiBold" Text="{Binding EndRoundLabel}" />
                        <ui:TextBlock Grid.Row="1"
                                      Grid.Column="0"
                                      Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                                      Text="{Binding EndRoundDescription}"
                                      TextWrapping="Wrap" />
                        <ui:NumberBox Grid.Row="0"
                                      Grid.RowSpan="2"
                                      Grid.Column="1"
                                      Width="120"
                                      Margin="0,0,36,0"
                                      Minimum="1"
                                      Maximum="999"
                                      SmallChange="1"
                                      Value="{Binding EndRound, Mode=TwoWay}" />
                    </Grid>

                    <Separator Margin="-18,0" BorderThickness="0,1,0,0" />
                    <Grid Margin="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <ui:TextBlock Grid.Row="0" FontWeight="SemiBold" Text="{Binding ResultSectionTitle}" />
                        <ui:TextBlock Grid.Row="1"
                                      Margin="0,6,0,0"
                                      Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                                      Text="{Binding RoundResultText}"
                                      TextWrapping="Wrap" />
                    </Grid>
                </StackPanel>
            </ui:CardExpander>

            <ui:CardExpander Margin="0,0,0,12"
                             ContentPadding="0"
                             Icon="{ui:SymbolIcon Info24}"
                             IsExpanded="True">
                <ui:CardExpander.Header>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <ui:TextBlock Grid.Row="0" Grid.Column="0" FontWeight="SemiBold" Text="{Binding HeroCardTitle}" TextWrapping="Wrap" />
                        <ui:TextBlock Grid.Row="1"
                                      Grid.Column="0"
                                      Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                                      Text="{Binding HeroCardDescription}"
                                      TextWrapping="Wrap" />
                        <ui:Button Grid.Row="0"
                                   Grid.RowSpan="2"
                                   Grid.Column="1"
                                   Width="120"
                                   Margin="0,0,36,0"
                                   Command="{Binding CalculateHeroCommand}"
                                   Content="{Binding CalculateButtonText}" />
                    </Grid>
                </ui:CardExpander.Header>

                <StackPanel>
                    <Separator Margin="-18,0" BorderThickness="0,1,0,0" />
                    <Grid Margin="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <ui:TextBlock Grid.Row="0" Grid.Column="0" FontWeight="SemiBold" Text="{Binding HeroLabel}" />
                        <ui:TextBlock Grid.Row="1"
                                      Grid.Column="0"
                                      Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                                      Text="{Binding HeroDescription}"
                                      TextWrapping="Wrap" />
                        <ComboBox Grid.Row="0"
                                  Grid.RowSpan="2"
                                  Grid.Column="1"
                                  Width="220"
                                  Margin="0,0,36,0"
                                  DisplayMemberPath="DisplayName"
                                  ItemsSource="{Binding HeroOptions}"
                                  SelectedItem="{Binding SelectedHero, Mode=TwoWay}" />
                    </Grid>

                    <Separator Margin="-18,0" BorderThickness="0,1,0,0" />
                    <Grid Margin="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <ui:TextBlock Grid.Row="0" Grid.Column="0" FontWeight="SemiBold" Text="{Binding HeroPlacementRoundLabel}" />
                        <ui:TextBlock Grid.Row="1"
                                      Grid.Column="0"
                                      Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                                      Text="{Binding HeroPlacementRoundDescription}"
                                      TextWrapping="Wrap" />
                        <ui:NumberBox Grid.Row="0"
                                      Grid.RowSpan="2"
                                      Grid.Column="1"
                                      Width="120"
                                      Margin="0,0,36,0"
                                      Minimum="1"
                                      Maximum="999"
                                      SmallChange="1"
                                      Value="{Binding HeroPlacementRound, Mode=TwoWay}" />
                    </Grid>

                    <Separator Margin="-18,0" BorderThickness="0,1,0,0" />
                    <Grid Margin="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <ui:TextBlock Grid.Row="0" Grid.Column="0" FontWeight="SemiBold" Text="{Binding HeroTargetRoundLabel}" />
                        <ui:TextBlock Grid.Row="1"
                                      Grid.Column="0"
                                      Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                                      Text="{Binding HeroTargetRoundDescription}"
                                      TextWrapping="Wrap" />
                        <ui:TextBox Grid.Row="0"
                                    Grid.RowSpan="2"
                                    Grid.Column="1"
                                    Width="120"
                                    Margin="0,0,36,0"
                                    Text="{Binding HeroTargetRound, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>

                    <Separator Margin="-18,0" BorderThickness="0,1,0,0" />
                    <Grid Margin="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <ui:TextBlock Grid.Row="0" Grid.Column="0" FontWeight="SemiBold" Text="{Binding HeroTargetLevelLabel}" />
                        <ui:TextBlock Grid.Row="1"
                                      Grid.Column="0"
                                      Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                                      Text="{Binding HeroTargetLevelDescription}"
                                      TextWrapping="Wrap" />
                        <ui:TextBox Grid.Row="0"
                                    Grid.RowSpan="2"
                                    Grid.Column="1"
                                    Width="120"
                                    Margin="0,0,36,0"
                                    Text="{Binding HeroTargetLevel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>

                    <Separator Margin="-18,0" BorderThickness="0,1,0,0" />
                    <Grid Margin="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <ui:TextBlock Grid.Row="0" FontWeight="SemiBold" Text="{Binding ResultSectionTitle}" />
                        <ui:TextBlock Grid.Row="1"
                                      Margin="0,6,0,0"
                                      Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                                      Text="{Binding HeroHintText}"
                                      TextWrapping="Wrap" />
                        <ui:TextBlock Grid.Row="2"
                                      Margin="0,8,0,0"
                                      Text="{Binding HeroResultText}"
                                      TextWrapping="Wrap" />
                    </Grid>
                </StackPanel>
            </ui:CardExpander>

            <ui:CardExpander Margin="0,0,0,12"
                             ContentPadding="0"
                             Icon="{ui:SymbolIcon ArrowDownload24}"
                             IsExpanded="True">
                <ui:CardExpander.Header>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <ui:TextBlock Grid.Row="0" Grid.Column="0" FontWeight="SemiBold" Text="{Binding ParagonCardTitle}" TextWrapping="Wrap" />
                        <ui:TextBlock Grid.Row="1"
                                      Grid.Column="0"
                                      Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                                      Text="{Binding ParagonCardDescription}"
                                      TextWrapping="Wrap" />
                        <ui:Button Grid.Row="0"
                                   Grid.RowSpan="2"
                                   Grid.Column="1"
                                   Width="120"
                                   Margin="0,0,36,0"
                                   Command="{Binding CalculateParagonCommand}"
                                   Content="{Binding CalculateButtonText}" />
                    </Grid>
                </ui:CardExpander.Header>

                <StackPanel>
                    <Separator Margin="-18,0" BorderThickness="0,1,0,0" />
                    <Grid Margin="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <ui:TextBlock Grid.Row="0" Grid.Column="0" FontWeight="SemiBold" Text="{Binding ParagonMonkeyLabel}" />
                        <ui:TextBlock Grid.Row="1"
                                      Grid.Column="0"
                                      Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                                      Text="{Binding ParagonMonkeyDescription}"
                                      TextWrapping="Wrap" />
                        <ComboBox Grid.Row="0"
                                  Grid.RowSpan="2"
                                  Grid.Column="1"
                                  Width="220"
                                  Margin="0,0,36,0"
                                  DisplayMemberPath="DisplayName"
                                  ItemsSource="{Binding ParagonMonkeyOptions}"
                                  SelectedItem="{Binding SelectedParagonMonkey, Mode=TwoWay}" />
                    </Grid>

                    <Separator Margin="-18,0" BorderThickness="0,1,0,0" />
                    <Grid Margin="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <ui:TextBlock Grid.Row="0" Grid.Column="0" FontWeight="SemiBold" Text="{Binding ParagonTotalPopsLabel}" />
                        <ui:TextBlock Grid.Row="1"
                                      Grid.Column="0"
                                      Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                                      Text="{Binding ParagonTotalPopsDescription}"
                                      TextWrapping="Wrap" />
                        <ui:NumberBox Grid.Row="0"
                                      Grid.RowSpan="2"
                                      Grid.Column="1"
                                      Width="160"
                                      Margin="0,0,36,0"
                                      Minimum="0"
                                      Maximum="999999999"
                                      SmallChange="1000"
                                      Value="{Binding ParagonTotalPops, Mode=TwoWay}" />
                    </Grid>

                    <Separator Margin="-18,0" BorderThickness="0,1,0,0" />
                    <Grid Margin="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <ui:TextBlock Grid.Row="0" Grid.Column="0" FontWeight="SemiBold" Text="{Binding ParagonUpgradeCountLabel}" />
                        <ui:TextBlock Grid.Row="1"
                                      Grid.Column="0"
                                      Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                                      Text="{Binding ParagonUpgradeCountDescription}"
                                      TextWrapping="Wrap" />
                        <ui:NumberBox Grid.Row="0"
                                      Grid.RowSpan="2"
                                      Grid.Column="1"
                                      Width="120"
                                      Margin="0,0,36,0"
                                      Minimum="0"
                                      Maximum="999"
                                      SmallChange="1"
                                      Value="{Binding ParagonUpgradeCount, Mode=TwoWay}" />
                    </Grid>

                    <Separator Margin="-18,0" BorderThickness="0,1,0,0" />
                    <Grid Margin="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <ui:TextBlock Grid.Row="0" Grid.Column="0" FontWeight="SemiBold" Text="{Binding ParagonExtraCashLabel}" />
                        <ui:TextBlock Grid.Row="1"
                                      Grid.Column="0"
                                      Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                                      Text="{Binding ParagonExtraCashDescription}"
                                      TextWrapping="Wrap" />
                        <ui:NumberBox Grid.Row="0"
                                      Grid.RowSpan="2"
                                      Grid.Column="1"
                                      Width="160"
                                      Margin="0,0,36,0"
                                      Minimum="0"
                                      Maximum="999999999"
                                      SmallChange="1000"
                                      Value="{Binding ParagonExtraCash, Mode=TwoWay}" />
                    </Grid>

                    <Separator Margin="-18,0" BorderThickness="0,1,0,0" />
                    <Grid Margin="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <ui:TextBlock Grid.Row="0" FontWeight="SemiBold" Text="{Binding ResultSectionTitle}" />
                        <ui:TextBlock Grid.Row="1"
                                      Margin="0,6,0,0"
                                      Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                                      Text="{Binding ParagonResultText}"
                                      TextWrapping="Wrap" />
                    </Grid>
                </StackPanel>
            </ui:CardExpander>
    </StackPanel>
</Page>
