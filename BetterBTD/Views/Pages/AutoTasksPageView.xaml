<Page x:Class="BetterBTD.Views.Pages.AutoTasksPageView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:controls="clr-namespace:BetterBTD.Views.Controls"
      mc:Ignorable="d">
    <StackPanel Margin="42,16,42,12">
        <ItemsControl ItemsSource="{Binding Tasks}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <ui:CardExpander Margin="0,0,0,12" ContentPadding="0" Icon="{ui:SymbolIcon PlayCircle24}">
                        <ui:CardExpander.Header>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <ui:TextBlock Grid.Row="0" Grid.Column="0" FontWeight="SemiBold" Text="{Binding Title}" TextWrapping="Wrap" />
                                <ui:TextBlock Grid.Row="1" Grid.Column="0" Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}" TextWrapping="Wrap">
                                    <Run Text="{Binding Description}" />
                                    <Run Text=" - " />
                                    <Hyperlink Command="{Binding DataContext.OpenTutorialCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                CommandParameter="{Binding}"
                                                Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}">
                                        <Run Text="{Binding DataContext.TutorialLinkText, RelativeSource={RelativeSource AncestorType=Page}, Mode=OneWay}" />
                                    </Hyperlink>
                                </ui:TextBlock>

                                <controls:TwoStateButton Grid.Row="0"
                                                            Grid.RowSpan="2"
                                                            Grid.Column="1"
                                                            Margin="0,0,24,0"
                                                            IsChecked="{Binding IsRunning, Mode=OneWay}"
                                                            EnableCommand="{Binding DataContext.ToggleTaskCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                            DisableCommand="{Binding DataContext.ToggleTaskCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                            EnableContent="{Binding RunningButtonText}"
                                                            DisableContent="{Binding RunningButtonText}"
                                                            EnableIcon="{ui:SymbolIcon Play24}"
                                                            DisableIcon="{ui:SymbolIcon Dismiss24}"
                                                            CommandParameter="{Binding}" />
                            </Grid>
                        </ui:CardExpander.Header>

                        <StackPanel>
                            <Separator Margin="-18,0" BorderThickness="0,1,0,0" />
                            <Grid Margin="16">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <ui:TextBlock Grid.Row="0" Grid.Column="0" FontWeight="SemiBold" Text="{Binding DataContext.OperationIntervalLabel, RelativeSource={RelativeSource AncestorType=Page}}" TextWrapping="Wrap" />
                                <ui:TextBlock Grid.Row="1" Grid.Column="0" Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}" Text="{Binding DataContext.OperationIntervalDescription, RelativeSource={RelativeSource AncestorType=Page}}" TextWrapping="Wrap" />
                                <ui:NumberBox Grid.Row="0"
                                                Grid.RowSpan="2"
                                                Grid.Column="1"
                                                Margin="0,0,36,0"
                                                Width="120"
                                                Minimum="20"
                                                Maximum="5000"
                                                SmallChange="10"
                                                Value="{Binding OperationIntervalMs, Mode=TwoWay}" />
                            </Grid>

                            <Separator Margin="-18,0" BorderThickness="0,1,0,0" />
                            <Grid Margin="16">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <ui:TextBlock Grid.Row="0" Grid.Column="0" FontWeight="SemiBold" Text="{Binding DataContext.MapLabel, RelativeSource={RelativeSource AncestorType=Page}}" TextWrapping="Wrap" />
                                <ui:TextBlock Grid.Row="1" Grid.Column="0" Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}" Text="{Binding DataContext.MapDescription, RelativeSource={RelativeSource AncestorType=Page}}" TextWrapping="Wrap" />
                                <ComboBox Grid.Row="0"
                                            Grid.RowSpan="2"
                                            Grid.Column="1"
                                            Width="200"
                                            Margin="0,0,36,0"
                                            ItemsSource="{Binding MapOptions}"
                                            SelectedItem="{Binding SelectedMap, Mode=TwoWay}" />
                            </Grid>

                            <Separator Margin="-18,0" BorderThickness="0,1,0,0" />
                            <Grid Margin="16">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <ui:TextBlock Grid.Row="0" Grid.Column="0" FontWeight="SemiBold" Text="{Binding DataContext.DifficultyLabel, RelativeSource={RelativeSource AncestorType=Page}}" TextWrapping="Wrap" />
                                <ui:TextBlock Grid.Row="1" Grid.Column="0" Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}" Text="{Binding DataContext.DifficultyDescription, RelativeSource={RelativeSource AncestorType=Page}}" TextWrapping="Wrap" />
                                <ComboBox Grid.Row="0"
                                            Grid.RowSpan="2"
                                            Grid.Column="1"
                                            Width="200"
                                            Margin="0,0,36,0"
                                            ItemsSource="{Binding DifficultyOptions}"
                                            SelectedItem="{Binding SelectedDifficulty, Mode=TwoWay}" />
                            </Grid>

                            <Separator Margin="-18,0" BorderThickness="0,1,0,0" />
                            <Grid Margin="16">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <ui:TextBlock Grid.Row="0" Grid.Column="0" FontWeight="SemiBold" Text="{Binding DataContext.ModeLabel, RelativeSource={RelativeSource AncestorType=Page}}" TextWrapping="Wrap" />
                                <ui:TextBlock Grid.Row="1" Grid.Column="0" Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}" Text="{Binding DataContext.ModeDescription, RelativeSource={RelativeSource AncestorType=Page}}" TextWrapping="Wrap" />
                                <ComboBox Grid.Row="0"
                                            Grid.RowSpan="2"
                                            Grid.Column="1"
                                            Width="200"
                                            Margin="0,0,36,0"
                                            ItemsSource="{Binding ModeOptions}"
                                            SelectedItem="{Binding SelectedMode, Mode=TwoWay}" />
                            </Grid>
                        </StackPanel>
                    </ui:CardExpander>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </StackPanel>
</Page>
