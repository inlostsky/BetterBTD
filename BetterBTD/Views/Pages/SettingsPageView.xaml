<Page x:Class="BetterBTD.Views.Pages.SettingsPageView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      mc:Ignorable="d">
    <StackPanel Margin="42,16,42,12">
        <ui:TextBlock Margin="0,0,0,8" FontWeight="SemiBold" Text="{Binding SoftwareSettingsTitle}" />

        <ui:CardControl Margin="0,0,0,12" Icon="{ui:SymbolIcon Globe24}">
            <ui:CardControl.Header>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ui:TextBlock Grid.Row="0" Grid.Column="0" FontWeight="SemiBold" Text="{Binding UiLanguageTitle}" TextWrapping="Wrap" />
                    <ui:TextBlock Grid.Row="1" Grid.Column="0" Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}" Text="{Binding UiLanguageSubtitle}" TextWrapping="Wrap" />
                    <ui:Button Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" Margin="0,0,12,0" Command="{Binding UpdateUiLanguageCommand}" Content="{Binding UpdateText}" />
                    <ComboBox Grid.Row="0"
                              Grid.RowSpan="2"
                              Grid.Column="2"
                              Width="200"
                              Margin="0,0,36,0"
                              DisplayMemberPath="DisplayName"
                              ItemsSource="{Binding UiLanguageOptions}"
                              SelectedItem="{Binding SelectedUiLanguage, Mode=TwoWay}" />
                </Grid>
            </ui:CardControl.Header>
        </ui:CardControl>

        <ui:CardControl Margin="0,0,0,12" Icon="{ui:SymbolIcon DarkTheme24}">
            <ui:CardControl.Header>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ui:TextBlock Grid.Row="0" Grid.Column="0" FontWeight="SemiBold" Text="{Binding ThemeTitle}" TextWrapping="Wrap" />
                    <ui:TextBlock Grid.Row="1" Grid.Column="0" Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}" Text="{Binding ThemeSubtitle}" TextWrapping="Wrap" />
                    <ComboBox Grid.Row="0"
                              Grid.RowSpan="2"
                              Grid.Column="1"
                              Width="200"
                              Margin="0,0,36,0"
                              DisplayMemberPath="DisplayName"
                              ItemsSource="{Binding ThemeOptions}"
                              SelectedItem="{Binding SelectedTheme, Mode=TwoWay}" />
                </Grid>
            </ui:CardControl.Header>
        </ui:CardControl>

        <ui:TextBlock Margin="0,0,0,8" FontWeight="SemiBold" Text="{Binding GameSettingsTitle}" />

        <ui:CardControl Margin="0,0,0,12" Icon="{ui:SymbolIcon LocalLanguage24}">
            <ui:CardControl.Header>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ui:TextBlock Grid.Row="0" Grid.Column="0" FontWeight="SemiBold" Text="{Binding GameLanguageTitle}" TextWrapping="Wrap" />
                    <ui:TextBlock Grid.Row="1" Grid.Column="0" Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}" Text="{Binding GameLanguageSubtitle}" TextWrapping="Wrap" />
                    <ComboBox Grid.Row="0"
                              Grid.RowSpan="2"
                              Grid.Column="1"
                              Width="200"
                              Margin="0,0,36,0"
                              DisplayMemberPath="DisplayName"
                              ItemsSource="{Binding GameLanguageOptions}"
                              SelectedItem="{Binding SelectedGameLanguage, Mode=TwoWay}" />
                </Grid>
            </ui:CardControl.Header>
        </ui:CardControl>

        <ui:CardExpander Margin="0,0,0,12" ContentPadding="0" Icon="{ui:SymbolIcon KeyboardMouse16}">
            <ui:CardExpander.Header>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <ui:TextBlock Grid.Row="0"
                                  Grid.Column="0"
                                  FontWeight="SemiBold"
                                  Text="{Binding KeyboardMouseSimulationTitle}"
                                  TextWrapping="Wrap" />
                    <ui:TextBlock Grid.Row="1"
                                  Grid.Column="0"
                                  Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                                  Text="{Binding KeyboardMouseSimulationSubtitle}"
                                  TextWrapping="Wrap" />
                </Grid>
            </ui:CardExpander.Header>
            <Grid Margin="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Row="0"
                        Grid.Column="0"
                        Padding="12"
                        Background="{ui:ThemeResource CardBackgroundFillColorSecondaryBrush}"
                        BorderBrush="{ui:ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                    <StackPanel>
                        <RadioButton GroupName="KeyboardMouseSimulationMode"
                                     Content="{Binding StandardKeyboardMouseSimulationTitle}"
                                     FontWeight="SemiBold"
                                     IsChecked="{Binding IsStandardKeyboardMouseSimulationModeSelected, Mode=TwoWay}" />
                        <ui:TextBlock Margin="24,6,0,0"
                                      Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                                      Text="{Binding StandardKeyboardMouseSimulationDescription}"
                                      TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="0"
                        Grid.Column="2"
                        Padding="12"
                        Background="{ui:ThemeResource CardBackgroundFillColorSecondaryBrush}"
                        BorderBrush="{ui:ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                    <StackPanel>
                        <RadioButton GroupName="KeyboardMouseSimulationMode"
                                     Content="{Binding HardwareKeyboardMouseSimulationTitle}"
                                     FontWeight="SemiBold"
                                     IsChecked="{Binding IsHardwareKeyboardMouseSimulationModeSelected, Mode=TwoWay}" />
                        <ui:TextBlock Margin="24,6,0,0"
                                      Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                                      Text="{Binding HardwareKeyboardMouseSimulationDescription}"
                                      TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <ui:TextBlock Grid.Row="1"
                              Grid.Column="0"
                              Grid.ColumnSpan="3"
                              Margin="0,12,0,0"
                              Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                              Text="{Binding KeyboardMouseSimulationStatusText}"
                              TextWrapping="Wrap" />
            </Grid>
        </ui:CardExpander>

        <ui:CardExpander Margin="0,0,0,12" ContentPadding="0" Icon="{ui:SymbolIcon KeyboardMouse16}">
            <ui:CardExpander.Header>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ui:TextBlock Grid.Row="0"
                                  Grid.Column="0"
                                  FontWeight="SemiBold"
                                  Text="{Binding KeyBindingsTitle}"
                                  TextWrapping="Wrap" />
                    <ui:TextBlock Grid.Row="1"
                                  Grid.Column="0"
                                  Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                                  Text="{Binding KeyBindingsSubtitle}"
                                  TextWrapping="Wrap" />
                    <ui:Button Grid.Row="0"
                               Grid.RowSpan="2"
                               Grid.Column="1"
                               Margin="0,0,20,0"
                               Command="{Binding OpenKeyBindingsWindowCommand}"
                               Content="{Binding ConfigureText}" />
                </Grid>
            </ui:CardExpander.Header>
            <StackPanel>
                <Grid Margin="16">
                    <ui:TextBlock Text="{Binding KeyBindingsBodyText}" TextWrapping="Wrap" />
                </Grid>
            </StackPanel>
        </ui:CardExpander>

        <ui:TextBlock Margin="0,0,0,8" FontWeight="SemiBold" Text="{Binding HelpTitle}" />

        <ui:CardExpander Margin="0,0,0,12" ContentPadding="0" Icon="{ui:SymbolIcon ArrowDownload24}">
            <ui:CardExpander.Header>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ui:TextBlock Grid.Row="0" Grid.Column="0" FontWeight="SemiBold" Text="{Binding CardUpdateTitle}" TextWrapping="Wrap" />
                    <ui:TextBlock Grid.Row="1" Grid.Column="0" Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}" Text="{Binding CardUpdateDescription}" TextWrapping="Wrap" />
                    <ui:Button Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" Margin="0,0,20,0" Command="{Binding CheckUpdateCommand}" Content="{Binding CheckUpdateText}" />
                </Grid>
            </ui:CardExpander.Header>
            <StackPanel>
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ui:TextBlock Grid.Row="0"
                                  Grid.Column="0"
                                  Grid.ColumnSpan="2"
                                  Margin="0,0,0,8"
                                  Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                                  Text="{Binding CurrentVersionText}"
                                  TextWrapping="Wrap" />
                    <ui:TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding CheckUpdateAlphaTitle}" TextWrapping="Wrap" />
                    <ui:TextBlock Grid.Row="2" Grid.Column="0" Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}" Text="{Binding CheckUpdateAlphaDescription}" TextWrapping="Wrap" />
                    <ui:Button Grid.Row="1" Grid.RowSpan="2" Grid.Column="1" Margin="0,0,36,0" Command="{Binding CheckUpdateAlphaCommand}" Content="{Binding CheckUpdateText}" />
                    <ui:TextBlock Grid.Row="3"
                                  Grid.Column="0"
                                  Grid.ColumnSpan="2"
                                  Margin="0,12,0,0"
                                  Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                                  Text="{Binding UpdateStatusText}"
                                  TextWrapping="Wrap" />
                </Grid>
            </StackPanel>
        </ui:CardExpander>

        <ui:CardControl Margin="0,0,0,12" Icon="{ui:SymbolIcon Info24}">
            <ui:CardControl.Header>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ui:TextBlock Grid.Row="0" Grid.Column="0" FontWeight="SemiBold" Text="{Binding CardAboutTitle}" TextWrapping="Wrap" />
                    <ui:TextBlock Grid.Row="1" Grid.Column="0" Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}" Text="{Binding CardAboutDescription}" TextWrapping="Wrap" />
                    <ui:Button Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" Margin="0,0,36,0" Command="{Binding OpenAboutCommand}" Content="{Binding OpenText}" />
                </Grid>
            </ui:CardControl.Header>
        </ui:CardControl>

        <ui:CardControl Margin="0,0,0,12" Icon="{ui:SymbolIcon Settings24}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <ui:Button Content="{Binding ResetButtonText}" Appearance="Secondary" Command="{Binding ResetCommand}" Margin="0,0,8,0" />
                <ui:Button Content="{Binding SaveButtonText}" Appearance="Primary" Command="{Binding SaveCommand}" />
            </StackPanel>
        </ui:CardControl>
    </StackPanel>
</Page>
