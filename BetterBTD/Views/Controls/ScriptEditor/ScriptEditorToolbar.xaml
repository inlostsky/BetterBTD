<UserControl x:Class="BetterBTD.Views.Controls.ScriptEditor.ScriptEditorToolbar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d"
             d:DesignHeight="80"
             d:DesignWidth="1200">
    <ui:CardControl Style="{StaticResource AppCardControlStyle}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ui:Button Grid.Column="0"
                       Margin="0,0,8,0"
                       Appearance="Primary"
                       Content="{Binding FileOpenText}"
                       Command="{Binding OpenScriptFileCommand}"
                       Icon="{ui:SymbolIcon FolderOpen24}" />
            <ui:DropDownButton Grid.Column="1"
                               Margin="0,0,8,0"
                               Content="{Binding FileSaveText}"
                               Command="{Binding SaveScriptFileCommand}"
                               Icon="{ui:SymbolIcon Save24}">
                <ui:DropDownButton.Flyout>
                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                        <MenuItem Header="{Binding FileSaveText}" Command="{Binding SaveScriptFileCommand}" />
                        <MenuItem Header="{Binding FileSaveAsText}" Command="{Binding SaveScriptFileAsCommand}" />
                    </ContextMenu>
                </ui:DropDownButton.Flyout>
            </ui:DropDownButton>
            <ui:Button Grid.Column="2"
                       Margin="0,0,8,0"
                       Content="{Binding FileNewText}"
                       Command="{Binding CreateNewScriptFileCommand}"
                       Icon="{ui:SymbolIcon DocumentAdd24}" />
            <ui:Button Grid.Column="3"
                       Margin="0,0,6,0"
                       Padding="6"
                       Appearance="Transparent"
                       BorderThickness="0"
                       Icon="{ui:SymbolIcon ArrowUndo24}"
                       Command="{Binding UndoSequenceCommand}" />
            <ui:Button Grid.Column="4"
                       Margin="0,0,8,0"
                       Padding="6"
                       Appearance="Transparent"
                       BorderThickness="0"
                       Icon="{ui:SymbolIcon ArrowRedo24}"
                       Command="{Binding RedoSequenceCommand}" />

            <TextBlock Grid.Column="5"
                       Margin="0,0,12,0"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                       Text="{Binding CurrentFileText}" />

            <ui:Button Grid.Column="6"
                       Appearance="Primary"
                       Content="{Binding DebugOpenRuntimeText}"
                       Command="{Binding RunScriptCommand}"
                       Icon="{ui:SymbolIcon PlayCircle24}" />
        </Grid>
    </ui:CardControl>
</UserControl>
