<UserControl x:Class="BetterBTD.Views.Controls.ScriptEditor.ScriptEditorWorkspace"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:dd="urn:gong-wpf-dragdrop"
             xmlns:controls="clr-namespace:BetterBTD.Views.Controls.ScriptEditor"
             mc:Ignorable="d"
             d:DesignHeight="900"
             d:DesignWidth="1200">
    <UserControl.Resources>
        <SolidColorBrush x:Key="NonExecutableInstructionBorderBrush" Color="#C48B18" />
        <SolidColorBrush x:Key="NonExecutableInstructionBackgroundBrush" Color="#1FC48B18" />

        <Style x:Key="FlatListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style x:Key="TransparentListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InstructionCardBorderStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorSecondaryBrush}" />
            <Setter Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsExecutable}" Value="False">
                    <Setter Property="BorderBrush" Value="{StaticResource NonExecutableInstructionBorderBrush}" />
                    <Setter Property="Background" Value="{StaticResource NonExecutableInstructionBackgroundBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentStrokeColorDefaultBrush}" />
                    <Setter Property="Background" Value="{DynamicResource AccentFillColorDefaultBrush}" />
                    <Setter Property="BorderThickness" Value="2" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="0,12,0,0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="160" />
            <ColumnDefinition Width="12" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="12" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Style="{StaticResource CardTitleTextStyle}"
                       Text="{Binding LibraryTitle}" />

            <ListBox Grid.Row="1"
                     Margin="0,10,0,0"
                     Style="{StaticResource FlatListBoxStyle}"
                     ItemContainerStyle="{StaticResource TransparentListBoxItemStyle}"
                     SelectionMode="Extended"
                     ItemsSource="{Binding InstructionLibrary}"
                     SelectedItem="{Binding SelectedLibraryInstruction}"
                     dd:DragDrop.IsDragSource="True"
                     dd:DragDrop.UseDefaultDragAdorner="True"
                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,8"
                                Padding="10"
                                CornerRadius="8"
                                BorderThickness="1"
                                Style="{StaticResource InstructionCardBorderStyle}">
                            <TextBlock Style="{StaticResource CardTitleTextStyle}"
                                       Text="{Binding DisplayName}" />
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Style="{StaticResource CardTitleTextStyle}"
                       Text="{Binding SequenceTitle}" />

            <Border Grid.Row="1"
                    Margin="0,10,0,0"
                    CornerRadius="8"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource ControlStrokeColorSecondaryBrush}"
                    Background="{DynamicResource ControlFillColorSecondaryBrush}">
                <ListBox x:Name="InstructionSequenceListBox"
                         Margin="10"
                         Style="{StaticResource FlatListBoxStyle}"
                         ItemContainerStyle="{StaticResource TransparentListBoxItemStyle}"
                         SelectionMode="Extended"
                         ItemsSource="{Binding InstructionSequence}"
                         SelectedItem="{Binding SelectedSequenceInstruction}"
                         SelectionChanged="InstructionSequenceListBox_SelectionChanged"
                         dd:DragDrop.IsDragSource="True"
                         dd:DragDrop.IsDropTarget="True"
                         dd:DragDrop.UseDefaultDragAdorner="True"
                         dd:DragDrop.SelectDroppedItems="True"
                         dd:DragDrop.DropHandler="{Binding}"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ScrollViewer.CanContentScroll="True"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling">
                    <ListBox.InputBindings>
                        <KeyBinding Key="C"
                                    Modifiers="Control"
                                    Command="{Binding DataContext.CopySelectedSequenceInstructionsCommand, ElementName=InstructionSequenceListBox}"
                                    CommandParameter="{Binding SelectedItems, ElementName=InstructionSequenceListBox}" />
                        <KeyBinding Key="V"
                                    Modifiers="Control"
                                    Command="{Binding DataContext.PasteSequenceInstructionsCommand, ElementName=InstructionSequenceListBox}"
                                    CommandParameter="{Binding SelectedItems, ElementName=InstructionSequenceListBox}" />
                        <KeyBinding Key="Delete"
                                    Command="{Binding DataContext.DeleteSelectedSequenceInstructionsCommand, ElementName=InstructionSequenceListBox}"
                                    CommandParameter="{Binding SelectedItems, ElementName=InstructionSequenceListBox}" />
                    </ListBox.InputBindings>
                    <ListBox.ContextMenu>
                        <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                            <MenuItem Header="{Binding CopySelectedInstructionText}"
                                      Command="{Binding CopySelectedSequenceInstructionsCommand}"
                                      CommandParameter="{Binding PlacementTarget.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                            <MenuItem Header="{Binding PasteInstructionText}"
                                      Command="{Binding PasteSequenceInstructionsCommand}"
                                      CommandParameter="{Binding PlacementTarget.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                            <Separator />
                            <MenuItem Header="{Binding DeleteSelectedInstructionText}"
                                      Command="{Binding DeleteSelectedSequenceInstructionsCommand}"
                                      CommandParameter="{Binding PlacementTarget.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                        </ContextMenu>
                    </ListBox.ContextMenu>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,8"
                                    Padding="10"
                                    CornerRadius="8"
                                    BorderThickness="1"
                                    Style="{StaticResource InstructionCardBorderStyle}">
                                <TextBlock Style="{StaticResource CardTitleTextStyle}"
                                           Text="{Binding DisplayName}" />
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <TextBlock Grid.Row="2"
                       Margin="0,10,0,0"
                       Style="{StaticResource CardDescriptionTextStyle}"
                       Text="{Binding SequenceEmptyText}"
                       Visibility="{Binding ShowSequenceEmptyState, Converter={StaticResource BoolToVisibilityConverter}}" />
        </Grid>

        <controls:ScriptInstructionPropertiesPanel Grid.Column="4" />
    </Grid>
</UserControl>
