<UserControl x:Class="BetterBTD.Views.Controls.ScriptEditor.ScriptEditorMetadataPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:vio="http://schemas.lepo.co/wpfui/2022/xaml/violeta"
             xmlns:converters="clr-namespace:BetterBTD.Views.Converters"
             mc:Ignorable="d"
             d:DesignHeight="120"
             d:DesignWidth="1200">
    <UserControl.Resources>
        <converters:MapTypeToCascadingItemConverter x:Key="MapTypeToCascadingItemConverter" />
    </UserControl.Resources>

    <ui:CardControl Style="{StaticResource AppCardControlStyle}">
        <Grid VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,12,0" VerticalAlignment="Center">
                <TextBlock Style="{StaticResource CardDescriptionTextStyle}" Text="{Binding MetadataMapText}" />
                <vio:CascadingComboBox Width="120"
                                       Margin="0,4,0,0"
                                       PlaceholderText="{Binding MetadataMapPlaceholderText}"
                                       ItemsSource="{Binding MapItems}"
                                       SelectedCascadingItem="{Binding SelectedMap, Mode=TwoWay, Converter={StaticResource MapTypeToCascadingItemConverter}}" />
            </StackPanel>

            <StackPanel Grid.Column="1" Margin="0,0,12,0" VerticalAlignment="Center">
                <TextBlock Style="{StaticResource CardDescriptionTextStyle}" Text="{Binding MetadataDifficultyText}" />
                <ComboBox Width="80"
                          Margin="0,4,0,0"
                          DisplayMemberPath="DisplayName"
                          ItemsSource="{Binding DifficultyOptions}"
                          SelectedItem="{Binding SelectedDifficultyOption}" />
            </StackPanel>

            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                <TextBlock Style="{StaticResource CardDescriptionTextStyle}" Text="{Binding MetadataModeText}" />
                <ComboBox Width="110"
                          Margin="0,4,0,0"
                          DisplayMemberPath="DisplayName"
                          ItemsSource="{Binding ModeOptions}"
                          SelectedItem="{Binding SelectedModeOption}" />
            </StackPanel>

            <StackPanel Grid.Column="3" Margin="12,0,0,0" VerticalAlignment="Center">
                <TextBlock Style="{StaticResource CardDescriptionTextStyle}" Text="{Binding MetadataHeroText}" />
                <ComboBox Width="110"
                          Margin="0,4,0,0"
                          DisplayMemberPath="DisplayName"
                          ItemsSource="{Binding HeroOptions}"
                          SelectedItem="{Binding SelectedHeroOption}" />
            </StackPanel>

            <StackPanel Grid.Column="4" Margin="12,0,0,0" VerticalAlignment="Center">
                <TextBlock Style="{StaticResource CardDescriptionTextStyle}" Text="{Binding MetadataTagText}" />
                <DockPanel Margin="0,4,0,0" LastChildFill="True">
                    <ui:Button DockPanel.Dock="Right"
                            Margin="8,0,0,0"
                            Padding="4"
                            Command="{Binding OpenTagEditorCommand}"
                            Icon="{ui:SymbolIcon Add16}" />
                    <TextBox MinWidth="180"
                             IsReadOnly="True"
                             Text="{Binding SelectedTagsSummaryText, Mode=OneWay}" />
                </DockPanel>
            </StackPanel>
        </Grid>
    </ui:CardControl>
</UserControl>
