                                <TextBlock Text="{Binding DataContext.PropertyWaitRoundCountText, ElementName=Root}"
                                           Style="{StaticResource PropertyCardTitleStyle}" />
                                <ui:NumberBox Margin="0,10,0,0"
                                              Minimum="1"
                                              Value="{Binding WaitRoundCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </ui:CardControl.Header>
                    </ui:CardControl>
                </StackPanel>

                <StackPanel>
