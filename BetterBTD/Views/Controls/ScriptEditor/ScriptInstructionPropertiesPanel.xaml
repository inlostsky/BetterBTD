                            <TextBlock Text="{Binding DataContext.PropertyCoordinateText, ElementName=Root}"
                                       Style="{StaticResource PropertyCardTitleStyle}" />
                        </ui:CardExpander.Header>
                        <StackPanel Margin="16">
