                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShowWaitRoundCount}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <ui:CardControl Style="{StaticResource PropertyCardStyle}">
