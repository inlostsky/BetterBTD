        <DataTemplate x:Key="NextRoundTemplate">
            <StackPanel>
                <ui:CardControl Style="{StaticResource PropertyCardStyle}">
                    <ui:CardControl.Header>
                        <StackPanel>
                            <TextBlock Text="{Binding DataContext.PropertyNextRoundActionText, ElementName=Root}"
                                       Style="{StaticResource PropertyCardTitleStyle}" />
                            <ComboBox Margin="0,10,0,0"
                                      DisplayMemberPath="DisplayName"
                                      SelectedValuePath="Code"
                                      ItemsSource="{Binding DataContext.NextRoundActionOptions, ElementName=Root}"
                                      SelectedValue="{Binding NextRoundAction, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </ui:CardControl.Header>
                </ui:CardControl>

                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel" BasedOn="{StaticResource CollapsedStackPanelStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShowNextRoundSendCount}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <ui:CardControl Style="{StaticResource PropertyCardStyle}">
                        <ui:CardControl.Header>
                            <StackPanel>
                                <TextBlock Text="{Binding DataContext.PropertyNextRoundSendCountText, ElementName=Root}"
                                           Style="{StaticResource PropertyCardTitleStyle}" />
