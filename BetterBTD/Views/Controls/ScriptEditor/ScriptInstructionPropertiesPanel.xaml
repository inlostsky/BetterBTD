<UserControl x:Class="BetterBTD.Views.Controls.ScriptEditor.ScriptInstructionPropertiesPanel"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:vio="http://schemas.lepo.co/wpfui/2022/xaml/violeta"
             xmlns:converters="clr-namespace:BetterBTD.Views.Converters"
             xmlns:local="clr-namespace:BetterBTD.Views.Controls.ScriptEditor"
             mc:Ignorable="d"
             d:DesignHeight="720"
             d:DesignWidth="360">
    <UserControl.Resources>
        <converters:MonkeyTowerTypeToCascadingItemConverter x:Key="MonkeyTowerTypeToCascadingItemConverter" />
        <SolidColorBrush x:Key="NonExecutableInstructionBorderBrush" Color="#C48B18" />
        <SolidColorBrush x:Key="NonExecutableInstructionBackgroundBrush" Color="#1FC48B18" />

        <Style x:Key="CollapsedStackPanelStyle" TargetType="StackPanel">
            <Setter Property="Visibility" Value="Collapsed" />
        </Style>

        <Style x:Key="PropertyCardStyle" TargetType="ui:CardControl" BasedOn="{StaticResource AppCardControlStyle}">
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>

        <Style x:Key="PropertyNestedCardStyle" TargetType="ui:CardControl" BasedOn="{StaticResource PropertyCardStyle}">
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>

        <Style x:Key="PropertyExpanderStyle" TargetType="ui:CardExpander" BasedOn="{StaticResource AppCardExpanderStyle}">
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="ContentPadding" Value="0" />
        </Style>

        <Style x:Key="PropertyCardTitleStyle" TargetType="TextBlock" BasedOn="{StaticResource CardTitleTextStyle}">
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <DataTemplate x:Key="PlaceMonkeyTemplate">
            <StackPanel>
                <ui:CardControl Style="{StaticResource PropertyCardStyle}">
                    <ui:CardControl.Header>
                        <StackPanel>
                            <TextBlock Text="{Binding DataContext.PropertyMonkeyTowerText, ElementName=Root}"
                                       Style="{StaticResource PropertyCardTitleStyle}" />
                            <vio:CascadingComboBox Margin="0,10,0,0"
                                                   PlaceholderText="{Binding DataContext.MetadataMapPlaceholderText, ElementName=Root}"
                                                   ItemsSource="{Binding DataContext.MonkeyTowerItems, ElementName=Root}"
                                                   SelectedCascadingItem="{Binding SelectedMonkeyTower, Mode=TwoWay, Converter={StaticResource MonkeyTowerTypeToCascadingItemConverter}}" />
                        </StackPanel>
                    </ui:CardControl.Header>
                </ui:CardControl>

                <ui:CardExpander Style="{StaticResource PropertyExpanderStyle}">
                    <ui:CardExpander.Header>
                        <TextBlock Text="{Binding DataContext.PropertyCoordinateText, ElementName=Root}"
                                   Style="{StaticResource PropertyCardTitleStyle}" />
                    </ui:CardExpander.Header>
                    <StackPanel Margin="16">
                        <ui:CardControl Style="{StaticResource PropertyNestedCardStyle}">
                            <ui:CardControl.Header>
                                <StackPanel>
                                    <TextBlock Text="X" Style="{StaticResource PropertyCardTitleStyle}" />
                                    <ui:NumberBox Margin="0,10,0,0"
                                                  Value="{Binding PositionX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </ui:CardControl.Header>
                        </ui:CardControl>

                        <ui:CardControl Style="{StaticResource PropertyCardStyle}">
                            <ui:CardControl.Header>
                                <StackPanel>
                                    <TextBlock Text="Y" Style="{StaticResource PropertyCardTitleStyle}" />
                                    <ui:NumberBox Margin="0,10,0,0"
                                                  Value="{Binding PositionY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </ui:CardControl.Header>
                        </ui:CardControl>
                    </StackPanel>
                </ui:CardExpander>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="UpgradeMonkeyTemplate">
            <StackPanel>
                <ui:CardControl Style="{StaticResource PropertyCardStyle}">
                    <ui:CardControl.Header>
                        <StackPanel>
                            <TextBlock Text="{Binding DataContext.PropertyTargetMonkeyText, ElementName=Root}"
                                       Style="{StaticResource PropertyCardTitleStyle}" />
                            <ComboBox Margin="0,10,0,0"
                                      DisplayMemberPath="DisplayName"
                                      SelectedValuePath="Code"
                                      ItemsSource="{Binding DataContext.MonkeyObjectOptions, ElementName=Root}"
                                      SelectedValue="{Binding TargetMonkeyBindingId, Mode=TwoWay}" />
                        </StackPanel>
                    </ui:CardControl.Header>
                </ui:CardControl>

                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel" BasedOn="{StaticResource CollapsedStackPanelStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShowUpgradePathSelector}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <ui:CardControl Style="{StaticResource PropertyCardStyle}">
                        <ui:CardControl.Header>
                            <StackPanel>
                                <TextBlock Text="{Binding DataContext.PropertyUpgradePathText, ElementName=Root}"
                                           Style="{StaticResource PropertyCardTitleStyle}" />
                                <ComboBox Margin="0,10,0,0"
                                          DisplayMemberPath="DisplayName"
                                          SelectedValuePath="Code"
                                          ItemsSource="{Binding DataContext.UpgradePathOptions, ElementName=Root}"
                                          SelectedValue="{Binding UpgradePath, Mode=TwoWay}" />
                            </StackPanel>
                        </ui:CardControl.Header>
                    </ui:CardControl>
                </StackPanel>

                <ui:CardControl Style="{StaticResource PropertyCardStyle}">
                    <ui:CardControl.Header>
                        <StackPanel>
                            <TextBlock Text="{Binding DataContext.PropertyUpgradeCountText, ElementName=Root}"
                                       Style="{StaticResource PropertyCardTitleStyle}" />
                            <ui:NumberBox Margin="0,10,0,0"
                                          Minimum="1"
                                          Maximum="5"
                                          Value="{Binding UpgradeCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </ui:CardControl.Header>
                </ui:CardControl>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="SwitchMonkeyTargetTemplate">
            <StackPanel>
                <ui:CardControl Style="{StaticResource PropertyCardStyle}">
                    <ui:CardControl.Header>
                        <StackPanel>
                            <TextBlock Text="{Binding DataContext.PropertyTargetMonkeyText, ElementName=Root}"
                                       Style="{StaticResource PropertyCardTitleStyle}" />
                            <ComboBox Margin="0,10,0,0"
                                      DisplayMemberPath="DisplayName"
                                      SelectedValuePath="Code"
                                      ItemsSource="{Binding DataContext.MonkeyObjectOptions, ElementName=Root}"
                                      SelectedValue="{Binding TargetMonkeyBindingId, Mode=TwoWay}" />
                        </StackPanel>
                    </ui:CardControl.Header>
                </ui:CardControl>

                <ui:CardControl Style="{StaticResource PropertyCardStyle}">
                    <ui:CardControl.Header>
                        <StackPanel>
                            <TextBlock Text="{Binding DataContext.PropertySwitchDirectionText, ElementName=Root}"
                                       Style="{StaticResource PropertyCardTitleStyle}" />
                            <ComboBox Margin="0,10,0,0"
                                      DisplayMemberPath="DisplayName"
                                      SelectedValuePath="Code"
                                      ItemsSource="{Binding DataContext.SwitchDirectionOptions, ElementName=Root}"
                                      SelectedValue="{Binding SwitchDirection, Mode=TwoWay}" />
                        </StackPanel>
                    </ui:CardControl.Header>
                </ui:CardControl>

                <ui:CardControl Style="{StaticResource PropertyCardStyle}">
                    <ui:CardControl.Header>
                        <StackPanel>
                            <TextBlock Text="{Binding DataContext.PropertySwitchCountText, ElementName=Root}"
                                       Style="{StaticResource PropertyCardTitleStyle}" />
                            <ui:NumberBox Margin="0,10,0,0"
                                          Minimum="1"
                                          Maximum="3"
                                          Value="{Binding SwitchCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </ui:CardControl.Header>
                </ui:CardControl>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="SetMonkeyAbilityTemplate">
