                                                  Value="{Binding PositionX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </ui:CardControl.Header>
                        </ui:CardControl>

                        <ui:CardControl Style="{StaticResource PropertyCardStyle}">
                            <ui:CardControl.Header>
                                <StackPanel>
                                    <TextBlock Text="Y" Style="{StaticResource PropertyCardTitleStyle}" />
                                    <ui:NumberBox Margin="0,10,0,0"
                                                  Value="{Binding PositionY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </ui:CardControl.Header>
                        </ui:CardControl>
                    </StackPanel>
                </ui:CardExpander>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="CommentTemplate">
            <ui:CardControl Style="{StaticResource PropertyCardStyle}">
                <ui:CardControl.Header>
                    <StackPanel>
                        <TextBlock Text="{Binding DataContext.PropertyCommentContentText, ElementName=Root}"
                                   Style="{StaticResource PropertyCardTitleStyle}" />
                        <TextBox Margin="0,10,0,0"
                                 MinHeight="100"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Text="{Binding CommentContent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </ui:CardControl.Header>
            </ui:CardControl>
        </DataTemplate>

        <local:ScriptInstructionTemplateSelector x:Key="InstructionTemplateSelector"
                                                 PlaceMonkeyTemplate="{StaticResource PlaceMonkeyTemplate}"
                                                 UpgradeMonkeyTemplate="{StaticResource UpgradeMonkeyTemplate}"
                                                 SwitchMonkeyTargetTemplate="{StaticResource SwitchMonkeyTargetTemplate}"
                                                 SetMonkeyAbilityTemplate="{StaticResource SetMonkeyAbilityTemplate}"
                                                 SellMonkeyTemplate="{StaticResource SellMonkeyTemplate}"
                                                 PlaceHeroInventoryTemplate="{StaticResource PlaceHeroInventoryTemplate}"
                                                 ActivateAbilityTemplate="{StaticResource ActivateAbilityTemplate}"
                                                 NextRoundTemplate="{StaticResource NextRoundTemplate}"
                                                 WaitTemplate="{StaticResource WaitTemplate}"
                                                 ModifyMonkeyCoordinateTemplate="{StaticResource ModifyMonkeyCoordinateTemplate}"
                                                 CommentTemplate="{StaticResource CommentTemplate}" />
    </UserControl.Resources>

    <StackPanel>
        <Border Margin="0,0,0,10"
                Padding="10"
                CornerRadius="8"
                BorderThickness="1"
                BorderBrush="{StaticResource NonExecutableInstructionBorderBrush}"
                Background="{StaticResource NonExecutableInstructionBackgroundBrush}">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ShowNonExecutableInstructionHint}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <TextBlock Text="{Binding NonExecutableInstructionHintText}"
                       TextWrapping="Wrap"
                       Style="{StaticResource CardDescriptionTextStyle}" />
        </Border>

        <TextBlock Text="{Binding PropertiesEmptyText}">
            <TextBlock.Style>
                <Style TargetType="TextBlock" BasedOn="{StaticResource CardDescriptionTextStyle}">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ShowPropertiesEmptyState}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <StackPanel>
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasSelectedSequenceInstruction}" Value="False">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>

            <ContentControl Content="{Binding SelectedSequenceInstruction}"
                            ContentTemplateSelector="{StaticResource InstructionTemplateSelector}" />

            <ui:CardControl Style="{StaticResource PropertyCardStyle}">
                <ui:CardControl.Header>
                    <StackPanel>
                        <TextBlock Text="{Binding PropertyNotesText}" Style="{StaticResource PropertyCardTitleStyle}" />
                        <TextBox Margin="0,10,0,0"
                                 MinHeight="100"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Text="{Binding SelectedSequenceInstruction.Notes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </ui:CardControl.Header>
            </ui:CardControl>
        </StackPanel>
    </StackPanel>
</UserControl>
