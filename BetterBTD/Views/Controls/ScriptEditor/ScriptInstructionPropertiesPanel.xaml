                                       Style="{StaticResource PropertyCardTitleStyle}" />
                            <ComboBox Margin="0,10,0,0"
                                      DisplayMemberPath="DisplayName"
                                      SelectedValuePath="Code"
                                      ItemsSource="{Binding DataContext.MonkeyObjectOptions, ElementName=Root}"
                                      SelectedValue="{Binding TargetMonkeyBindingId, Mode=TwoWay}" />
                        </StackPanel>
                    </ui:CardControl.Header>
                </ui:CardControl>

                <ui:CardControl Style="{StaticResource PropertyCardStyle}">
                    <ui:CardControl.Header>
                        <StackPanel>
                            <TextBlock Text="{Binding DataContext.PropertyAbilityText, ElementName=Root}"
                                       Style="{StaticResource PropertyCardTitleStyle}" />
                            <ComboBox Margin="0,10,0,0"
                                      DisplayMemberPath="DisplayName"
                                      SelectedValuePath="Code"
                                      ItemsSource="{Binding DataContext.MonkeyAbilityOptions, ElementName=Root}"
                                      SelectedValue="{Binding SelectedAbility, Mode=TwoWay}" />
                        </StackPanel>
                    </ui:CardControl.Header>
                </ui:CardControl>

                <ui:CardControl Style="{StaticResource PropertyCardStyle}">
                    <ui:CardControl.Header>
                        <ui:ToggleSwitch Content="{Binding DataContext.PropertyNeedAbilityCoordinateText, ElementName=Root}"
                                         IsChecked="{Binding RequiresAbilityCoordinate, Mode=TwoWay}" />
                    </ui:CardControl.Header>
                </ui:CardControl>

                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel" BasedOn="{StaticResource CollapsedStackPanelStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding RequiresAbilityCoordinate}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <ui:CardExpander Style="{StaticResource PropertyExpanderStyle}">
                        <ui:CardExpander.Header>
                            <TextBlock Text="{Binding DataContext.PropertyCoordinateText, ElementName=Root}"
                                       Style="{StaticResource PropertyCardTitleStyle}" />
                        </ui:CardExpander.Header>
                        <StackPanel Margin="16">
                            <ui:CardControl Style="{StaticResource PropertyNestedCardStyle}">
                                <ui:CardControl.Header>
                                    <StackPanel>
                                        <TextBlock Text="X" Style="{StaticResource PropertyCardTitleStyle}" />
                                        <ui:NumberBox Margin="0,10,0,0"
                                                      Value="{Binding AbilityCoordinateX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                </ui:CardControl.Header>
                            </ui:CardControl>

                            <ui:CardControl Style="{StaticResource PropertyCardStyle}">
                                <ui:CardControl.Header>
                                    <StackPanel>
                                        <TextBlock Text="Y" Style="{StaticResource PropertyCardTitleStyle}" />
                                        <ui:NumberBox Margin="0,10,0,0"
                                                      Value="{Binding AbilityCoordinateY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                </ui:CardControl.Header>
                            </ui:CardControl>
                        </StackPanel>
                    </ui:CardExpander>
                </StackPanel>
            </StackPanel>
        </DataTemplate>

