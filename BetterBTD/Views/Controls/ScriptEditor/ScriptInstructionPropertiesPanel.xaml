        <DataTemplate x:Key="ModifyMonkeyCoordinateTemplate">
            <StackPanel>
                <ui:CardControl Style="{StaticResource PropertyCardStyle}">
                    <ui:CardControl.Header>
                        <StackPanel>
                            <TextBlock Text="{Binding DataContext.PropertyTargetMonkeyText, ElementName=Root}"
