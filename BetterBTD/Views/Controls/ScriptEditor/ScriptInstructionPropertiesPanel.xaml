                        <Style TargetType="StackPanel" BasedOn="{StaticResource CollapsedStackPanelStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShowWaitCoordinateColor}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <ui:CardExpander Style="{StaticResource PropertyExpanderStyle}">
