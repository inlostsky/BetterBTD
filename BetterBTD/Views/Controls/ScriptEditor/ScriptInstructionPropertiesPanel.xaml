                                    </StackPanel>
                                </ui:CardControl.Header>
                            </ui:CardControl>

                            <ui:CardControl Style="{StaticResource PropertyCardStyle}">
                                <ui:CardControl.Header>
                                    <StackPanel>
                                        <TextBlock Text="Y" Style="{StaticResource PropertyCardTitleStyle}" />
                                        <ui:NumberBox Margin="0,10,0,0"
                                                      Value="{Binding WaitColorCoordinateY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                </ui:CardControl.Header>
                            </ui:CardControl>
                        </StackPanel>
                    </ui:CardExpander>

                    <ui:CardControl Style="{StaticResource PropertyCardStyle}">
                        <ui:CardControl.Header>
                            <StackPanel>
                                <TextBlock Text="{Binding DataContext.PropertyWaitColorHexText, ElementName=Root}"
                                           Style="{StaticResource PropertyCardTitleStyle}" />
                                <TextBox Margin="0,10,0,0"
                                         Text="{Binding WaitColorHex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </ui:CardControl.Header>
                    </ui:CardControl>

                    <ui:CardControl Style="{StaticResource PropertyCardStyle}">
                        <ui:CardControl.Header>
                            <StackPanel>
                                <TextBlock Text="{Binding DataContext.PropertyWaitColorToleranceText, ElementName=Root}"
                                           Style="{StaticResource PropertyCardTitleStyle}" />
                                <ui:NumberBox Margin="0,10,0,0"
                                              Minimum="0"
                                              Maximum="255"
                                              Value="{Binding WaitColorTolerance, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </ui:CardControl.Header>
                    </ui:CardControl>
                </StackPanel>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="SellMonkeyTemplate">
            <ui:CardControl Style="{StaticResource PropertyCardStyle}">
                <ui:CardControl.Header>
                    <StackPanel>
                        <TextBlock Text="{Binding DataContext.PropertyTargetMonkeyText, ElementName=Root}"
                                   Style="{StaticResource PropertyCardTitleStyle}" />
                        <ComboBox Margin="0,10,0,0"
                                  DisplayMemberPath="DisplayName"
                                  SelectedValuePath="Code"
                                  ItemsSource="{Binding DataContext.MonkeyObjectOptions, ElementName=Root}"
