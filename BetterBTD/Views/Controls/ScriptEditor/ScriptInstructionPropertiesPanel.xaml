                            </StackPanel>
                        </ui:CardControl.Header>
                    </ui:CardControl>
                </StackPanel>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="WaitTemplate">
            <StackPanel>
                <ui:CardControl Style="{StaticResource PropertyCardStyle}">
                    <ui:CardControl.Header>
                        <StackPanel>
                            <TextBlock Text="{Binding DataContext.PropertyWaitModeText, ElementName=Root}"
                                       Style="{StaticResource PropertyCardTitleStyle}" />
                            <ComboBox Margin="0,10,0,0"
                                      DisplayMemberPath="DisplayName"
                                      SelectedValuePath="Code"
                                      ItemsSource="{Binding DataContext.WaitModeOptions, ElementName=Root}"
                                      SelectedValue="{Binding WaitMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </ui:CardControl.Header>
                </ui:CardControl>

                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel" BasedOn="{StaticResource CollapsedStackPanelStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShowWaitTimeMilliseconds}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <ui:CardControl Style="{StaticResource PropertyCardStyle}">
                        <ui:CardControl.Header>
                            <StackPanel>
                                <TextBlock Text="{Binding DataContext.PropertyWaitTimeMillisecondsText, ElementName=Root}"
                                           Style="{StaticResource PropertyCardTitleStyle}" />
                                <ui:NumberBox Margin="0,10,0,0"
                                              Minimum="0"
                                              Value="{Binding WaitTimeMilliseconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
