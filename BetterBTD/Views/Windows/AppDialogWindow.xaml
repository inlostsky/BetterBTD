<ui:FluentWindow x:Class="BetterBTD.Views.Windows.AppDialogWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 mc:Ignorable="d"
                 Width="640"
                 MinWidth="560"
                 MaxWidth="860"
                 SizeToContent="Height"
                 ResizeMode="NoResize"
                 ShowInTaskbar="False"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 WindowCornerPreference="Round"
                 WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar x:Name="DialogTitleBar" Grid.Row="0">
            <ui:TitleBar.Icon>
                <ui:SymbolIcon Symbol="Info24" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <ui:CardControl Grid.Row="1"
                        Margin="24,16,24,0"
                        Style="{StaticResource AppCardControlStyle}">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          MaxHeight="420">
                <StackPanel>
                    <TextBlock x:Name="MessageTextBlock"
                               Style="{StaticResource CardTitleTextStyle}"
                               TextWrapping="Wrap" />
                    <TextBlock x:Name="SelectableTextLabelBlock"
                               Margin="0,16,0,6"
                               Style="{StaticResource CardDescriptionTextStyle}" />
                    <TextBox x:Name="SelectableTextBox"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto" />
                </StackPanel>
            </ScrollViewer>
        </ui:CardControl>

        <StackPanel Grid.Row="2"
                    Margin="24,16,24,20"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
            <ui:Button x:Name="CloseButtonControl"
                       Margin="0,0,8,0"
                       Appearance="Secondary"
                       Click="CloseButtonControl_OnClick" />
            <ui:Button x:Name="SecondaryButtonControl"
                       Margin="0,0,8,0"
                       Appearance="Secondary"
                       Click="SecondaryButtonControl_OnClick" />
            <ui:Button x:Name="PrimaryButtonControl"
                       Appearance="Primary"
                       Click="PrimaryButtonControl_OnClick" />
        </StackPanel>
    </Grid>
</ui:FluentWindow>
